# Dependencies
node_modules/

# Environment variables — never commit credentials
.env
.env.local
.env*.local

# Playwright output
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Auth state — contains session cookies, never commit
.auth/


# Claude — commit agent definitions and memory, ignore local settings
.claude/settings.local.json

# Winston logs — generated at runtime, never committed
logs/

# OS files
.DS_Store
Thumbs.db
